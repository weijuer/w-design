{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "jsx": "preserve",
        "allowJs": false,
        "sourceMap": false,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "esModuleInterop": true,
        "removeComments": false,
        "rootDir": ".",
        "types": [],
        "paths": {
            "@w-design/components": ["./packages/components"],
            "@w-design/components/*": ["./packages/components/*"],
            "@w-design/utils": ["./packages/utils"],
            "@w-design/utils/*": ["./packages/utils/*"],
            "@w-design/hooks": ["./packages/hooks"],
            "@w-design/constants": ["./packages/constants"],
            "w-design-chat": ["./packages/w-design-chat"],
            "w-design-vue": ["./packages/design-vue"]
        }
    },
    "preserveSymlinks": true
}
